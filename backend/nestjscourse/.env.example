# DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lorawan_db

# AUTHENTICATION
JWT_SECRET=generate_a_strong_secret_key_here
JWT_EXPIRES_IN=1d
CORS_ORIGINS=http://localhost:3000,http://dashboard.yourdomain.com

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# InfluxDB 2.0
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_influx_token
INFLUX_ORG=lora_org
INFLUX_BUCKET=sensor_readings
